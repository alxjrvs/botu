{
  "name": "boom",
  "version": "0.12.0",
  "description": "BoomTube — a declarative machine reconciler (executable: boom). Converge your machine from a declarative boomfile.toml — dotfiles, packages, and tools (sync/verify) with drift detection and rollback — then open portals to your code.",
  "type": "module",
  "private": true,
  "bin": {
    "boom": "./build/boom"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile build/boom",
    "test": "bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "check": "biome check . && tsc --noEmit && bun test",
    "site:build": "bun run site/build.ts"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@stricli/core": "1.2.7",
    "smol-toml": "1.6.1",
    "valibot": "1.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/bun": "1.3.14",
    "marked": "^18.0.6",
    "typescript": "6.0.3"
  }
}
