{
  "name": "botu",
  "version": "0.0.1",
  "description": "An installable dotfiles + workspace engine. apply/verify/fix your machine from a declarative botufile.toml, and open portals to your code workspaces.",
  "type": "module",
  "private": true,
  "bin": {
    "botu": "./build/botu"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile build/botu",
    "test": "bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "check": "biome check . && tsc --noEmit && bun test"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@stricli/core": "1.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/bun": "1.3.14",
    "typescript": "6.0.3"
  }
}
