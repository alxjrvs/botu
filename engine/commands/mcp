#!/usr/bin/env bash
# mcp — register MCP servers the 1Password-native way (ported from dot mcp).
# `botu mcp add NAME -- <server>` wraps `claude mcp add` to run the server under
# `op run --env-file=.env` so secrets resolve from op:// refs, never on disk.
set -euo pipefail
OP_BIN="/opt/homebrew/bin/op"
KEYCHAIN_ITEM="op-claude-agent"
die() {
  printf 'botu mcp: %s\n' "$*" >&2
  exit 2
}
[[ "${1:-}" == "add" ]] || die "usage: botu mcp add <name> [--scope S] [--env-file F] [--agent] -- <server-cmd>"
shift
name=""
scope="project"
env_file=".env"
agent=0
while [[ $# -gt 0 ]]; do case "$1" in
  --scope)
    scope="$2"
    shift 2
    ;;
  --env-file)
    env_file="$2"
    shift 2
    ;;
  --agent)
    agent=1
    shift
    ;;
  --)
    shift
    break
    ;;
  -*) die "unknown flag: $1" ;; *)
    name="$1"
    shift
    ;;
esac done
[[ -n "$name" && $# -ge 1 ]] || die "need <name> and a server command after --"
command -v claude > /dev/null 2>&1 || die "claude not on PATH"
if [[ "$agent" -eq 1 ]]; then
  set -- sh -c "OP_SERVICE_ACCOUNT_TOKEN=\"\$(security find-generic-password -s ${KEYCHAIN_ITEM} -w)\" ${OP_BIN} run --env-file=${env_file} -- $*"
else
  set -- op run --env-file="${env_file}" -- "$@"
fi
exec claude mcp add "$name" --scope "$scope" -- "$@"
