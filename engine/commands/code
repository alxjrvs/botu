#!/usr/bin/env bash
# code — mirror your code dir into agent workspaces (the former `dot ws`, now a
# core botu command). Boom-Tube flavor: each repo becomes a portal you can step
# into. Subcommands:
#   code init [DIR]   record the code dir (default ~/Code) to memory
#   code claude       one idle `claude --bg` background agent per repo
#   code cmux         one cmux workspace per repo
#
# Code-dir resolution (independent of the dotfiles repo):
#   $BOTU_CODE env  →  breadcrumb from `code init`  →  ~/Code
#
# PROTOTYPE: claude/cmux print the plan (the crawl + per-repo action) but do not
# actually spawn agents or drive cmux — that heavy backend is out of scope here.
set -euo pipefail

_crumb() { printf '%s/botu/code' "${XDG_STATE_HOME:-$HOME/.local/state}"; }

_resolve_code() {
  local c crumb recorded=""
  crumb="$(_crumb)"
  [[ -f "$crumb" ]] && recorded="$(< "$crumb")"
  for c in "${BOTU_CODE:-}" "$recorded" "$HOME/Code"; do
    [[ -n "$c" && -d "$c" ]] && {
      printf '%s' "$c"
      return 0
    }
  done
  return 1
}

# _repos ROOT: emit each git repo under ROOT (leaf rule — a repo is a leaf, so
# we never descend into worktrees/submodules to spawn stray workspaces).
_repos() {
  local root="$1" g d
  find "$root" -maxdepth 3 -name .git 2> /dev/null | while read -r g; do
    d="$(dirname "$g")"
    case "$d" in
      *.claude/worktrees* | */.worktrees/*) continue ;;
    esac
    printf '%s\n' "$d"
  done | sort -u
}

sub="${1:-}"
[[ $# -ge 1 ]] && shift || true

case "$sub" in
  init)
    target="${1:-$HOME/Code}"
    target="$(cd "$target" 2> /dev/null && pwd || true)"
    [[ -n "$target" && -d "$target" ]] || {
      printf 'botu code init: not a directory: %s\n' "${1:-$HOME/Code}" >&2
      exit 1
    }
    crumb="$(_crumb)"
    mkdir -p "$(dirname "$crumb")"
    printf '%s\n' "$target" > "$crumb"
    printf 'botu: code dir recorded → %s\n' "$target"
    ;;
  claude | cmux)
    root="$(_resolve_code)" || {
      printf 'botu code: no code dir — run: botu code init [DIR]\n' >&2
      exit 1
    }
    printf '\033[1m==> botu code %s\033[0m  (%s)\n' "$sub" "$root"
    n=0
    while read -r repo; do
      [[ -n "$repo" ]] || continue
      n=$((n + 1))
      rel="${repo#"$root"/}"
      case "$sub" in
        claude) printf '  • %-28s → would launch: claude --bg (idle agent)\n' "$rel" ;;
        cmux) printf '  • %-28s → would create cmux workspace\n' "$rel" ;;
      esac
    done < <(_repos "$root")
    printf '\033[0;36m   %d repo(s) — prototype: plan only, nothing launched\033[0m\n' "$n"
    ;;
  "" | -h | --help)
    printf 'usage: botu code <init [DIR] | claude | cmux>\n'
    ;;
  *)
    printf 'botu code: unknown subcommand: %s\n' "$sub" >&2
    exit 2
    ;;
esac
