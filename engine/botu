#!/usr/bin/env bash
# botu — the installed executable's entrypoint (prototype).
#
# Named for the Boom Tube (Kirby's Fourth World): it opens portals — to your
# machine's ideal state (apply/verify/fix) and to your code workspaces (code).
# In the extracted universe this lives on PATH (brew / installer), NOT in any
# dotfiles repo.
#
# Dispatch:
#   1. core reconcile verbs (apply/verify/fix/update) → engine/run  [need a repo]
#   2. anything else → discovered in engine/commands then <config>/commands
#      (e.g. `code`), which do NOT require a dotfiles repo.
#
# Config-repo resolution (first dir containing a `botufile` wins):
#   $BOTU_CONFIG env  →  breadcrumb from `botu init`  →  $PWD  →  ~/dotFiles
set -euo pipefail

ENGINE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
_crumb() { printf '%s/botu/config' "${XDG_STATE_HOME:-$HOME/.local/state}"; }

_resolve_config() {
  local c crumb recorded=""
  crumb="$(_crumb)"
  [[ -f "$crumb" ]] && recorded="$(< "$crumb")"
  for c in "${BOTU_CONFIG:-}" "$recorded" "$PWD" "$HOME/dotFiles"; do
    [[ -n "$c" && -f "$c/botufile" ]] && {
      printf '%s' "$c"
      return 0
    }
  done
  return 1
}

_list_commands() {
  local d
  for d in "$ENGINE_DIR/commands" "${BOTU_CONFIG:-}/commands"; do
    [[ -d "$d" ]] || continue
    find "$d" -maxdepth 1 -type f -perm -u+x -exec basename {} \;
  done 2> /dev/null | sort -u | paste -sd' ' -
}

cmd="${1:-}"
[[ $# -ge 1 ]] && shift || true

# ── botu init [PATH]: locate + persist the dotfiles repo (re-sourceable) ──────
if [[ "$cmd" == "init" ]]; then
  target="${1:-$PWD}"
  target="$(cd "$target" 2> /dev/null && pwd || true)"
  [[ -n "$target" && -f "$target/botufile" ]] || {
    # shellcheck disable=SC2016  # backticks are literal text in the message
    printf 'botu init: no `botufile` at %s — point me at your dotfiles repo: botu init /path/to/repo\n' "${1:-$PWD}" >&2
    exit 1
  }
  crumb="$(_crumb)"
  mkdir -p "$(dirname "$crumb")"
  printf '%s\n' "$target" > "$crumb"
  printf 'botu: dotfiles repo recorded → %s\n' "$target"

  # Leave a self-contained bootstrap so a fresh clone installs in one command:
  # curl+install botu, point it here, apply. Regenerated each init (idempotent).
  boot="$target/botuinit.sh"
  cat > "$boot" << 'BOOTSTRAP'
#!/usr/bin/env sh
# botuinit.sh — bootstrap this dotfiles repo on a fresh machine. One command:
#   git clone <repo> && ./<repo>/botuinit.sh
# Installs botu if missing, points it at this repo, and applies. Generated by
# `botu init` — do not edit by hand (re-run `botu init` to refresh).
set -eu
REPO="$(cd "$(dirname "$0")" && pwd)"
if ! command -v botu > /dev/null 2>&1; then
  echo "botuinit: installing botu…"
  curl -fsSL https://raw.githubusercontent.com/alxjrvs/botu/main/install.sh | sh
fi
botu init "$REPO"
botu apply "$@"
BOOTSTRAP
  chmod +x "$boot"
  printf 'botu: wrote bootstrap → %s\n' "$boot"
  exit 0
fi

# ── Best-effort config resolution: required only by the reconcile verbs ───────
if CONFIG_DIR="$(_resolve_config)"; then
  export BOTU_CONFIG="$CONFIG_DIR"
fi

_need_config() {
  [[ -n "${BOTU_CONFIG:-}" ]] && return 0
  # shellcheck disable=SC2016  # backticks are literal text in the message
  printf 'botu %s: no dotfiles repo found — run `botu init [PATH]`\n' "$1" >&2
  exit 1
}

case "$cmd" in
  "" | -h | --help)
    printf 'usage: botu <init|apply|verify|fix|update> | <command> [args]\n'
    printf '  config: %s\n' "${BOTU_CONFIG:-<none — run: botu init>}"
    printf '  tools:  %s\n' "$(_list_commands)"
    ;;
  --version | -V) printf 'botu 0.0.0-proto\n' ;;
  apply | verify | fix)
    _need_config "$cmd"
    exec "$ENGINE_DIR/run" "$cmd" "$@"
    ;;
  update)
    _need_config update
    exec "$ENGINE_DIR/run" apply --upgrade "$@"
    ;;
  *)
    # Tier 2: discovered subcommands (engine-shipped, then config-supplied).
    # These run with no dotfiles repo — e.g. `botu code` works standalone.
    for _base in "$ENGINE_DIR/commands" "${BOTU_CONFIG:-}/commands"; do
      [[ -x "$_base/$cmd" ]] && exec "$_base/$cmd" "$@"
    done
    printf 'botu: unknown subcommand: %s\n' "$cmd" >&2
    printf '  core:  apply verify fix update\n' >&2
    printf '  tools: %s\n' "$(_list_commands)" >&2
    exit 2
    ;;
esac
